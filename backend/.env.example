# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Database
DATABASE_URL=postgres://madem:madem@localhost:5432/madem_crm

# Auth
JWT_SECRET=change-me-in-prod-please-use-a-long-random-string
COOKIE_SECRET=change-me-too-another-long-random-string
COOKIE_NAME=madem_session
COOKIE_SECURE=false

# CORS (comma-separated allowlist of frontend origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Seed admin (used by db:seed)
ADMIN_EMAIL=admin@madem.local
ADMIN_PASSWORD=admin12345
ADMIN_NAME=MADEM Admin

# Object storage (S3-compatible: R2 / MinIO) — used later for uploads
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=madem-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000/madem-media
